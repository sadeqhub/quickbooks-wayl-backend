# Intuit Developer app (Keys & OAuth in developer.intuit.com)
INTUIT_CLIENT_ID=your_client_id
INTUIT_CLIENT_SECRET=your_client_secret
INTUIT_REDIRECT_URI=http://localhost:8000/callback
INTUIT_ENVIRONMENT=sandbox

# Wayl API — https://api.thewayl.com/reference
# Merchants provide their own API key via POST /api/settings/wayl (no global key required).
WAYL_API_BASE=https://api.thewayl.com
# Wayl link creation requires webhook and redirect. Defaults: {APP_BASE_URL}/api/webhook/wayl, {APP_BASE_URL}/app, and a default secret. Override for production.
# WAYL_WEBHOOK_URL=
# WAYL_WEBHOOK_SECRET=
# WAYL_REDIRECTION_URL=
# Optional: image URL used in lineItem[*].image (Wayl requires it)
# WAYL_LINE_ITEM_IMAGE=http://localhost:8000/img/invoice.svg
# Optional: convert non-IQD invoice totals to IQD for payment links. Default 1320 (1 USD = 1320 IQD). Wayl requires amounts in IQD (min 1000).
# USD_TO_IQD=1320

# Server & Intuit app URLs (for Launch / Disconnect / Connect in developer.intuit.com)
PORT=8000
APP_BASE_URL=http://localhost:8000
